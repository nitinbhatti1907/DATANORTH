# DATANORTH - environment configuration
# Copy this file to .env.local and fill in values.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database - Supabase Postgres
# Use the Supabase pooled connection string for Vercel deployments.
DATABASE_URL=

# Admin authentication - Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Admin uploads
# Leave false until Supabase credentials are configured.
ADMIN_UPLOADS_ENABLED=false
# Optional comma-separated allowlist for admin/upload access.
# If empty, any signed-in Clerk user can access admin pages.
ADMIN_EMAILS=

# SAH ED wait-time scraper (optional - disabled by default)
# ENABLE_ED_WAIT_TIME=false
# LUMA_API_URL=
# LUMA_API_TOKEN=
